# P21 API Documentation MCP Server Configuration
# Copy this file to .env and adjust values as needed.

# Server host and port
MCP_HOST=0.0.0.0
MCP_PORT=8000

# Transport mode: "streamable-http" or "stdio"
MCP_TRANSPORT=streamable-http

# GitHub repository for P21 API documentation (owner/repo)
GITHUB_REPO=mrwuss/p21-api-documentation

# GitHub branch to fetch docs from
GITHUB_BRANCH=master
